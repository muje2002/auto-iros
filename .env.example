# CODEF API 인증 정보
# https://developer.codef.io 에서 발급받은 클라이언트 정보
CODEF_CLIENT_ID=your_client_id_here
CODEF_CLIENT_SECRET=your_client_secret_here

# CODEF API 환경 설정
# demo: 데모(개발/테스트), sandbox: 샌드박스(고정응답), production: 운영
CODEF_ENV=demo

# CODEF RSA 공개키 (필수 - CODEF 개발자센터에서 발급)
CODEF_PUBLIC_KEY=your_public_key_here

# CODEF 필수 파라미터
CODEF_PHONE_NO=01000000000
CODEF_PASSWORD=1234

# 선불전자지급수단 (전자민원캐시) - 발급(issueType=0) 시 필수
EPREPAY_NO=
EPREPAY_PASS=

# 출력 디렉토리
OUTPUT_DIR=./output
